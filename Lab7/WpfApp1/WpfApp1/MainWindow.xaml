<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox HorizontalAlignment="Center" Margin="0,68,0,0" TextWrapping="Wrap" Text="Selllect a message option and then choose the Display button" VerticalAlignment="Top" Width="336"/>
        <RadioButton x:Name="GoodbyeButton" Content="Bye" HorizontalAlignment="Left" Margin="483,163,0,0" VerticalAlignment="Top" RenderTransformOrigin="1.376,3.626"/>
        <RadioButton x:Name="HellButton" Content="Hello" HorizontalAlignment="Left" Margin="232,163,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked" IsChecked="True"/>
        <Button Content="Display" HorizontalAlignment="Center" Margin="0,244,0,0" VerticalAlignment="Top" Click="Button_Click_1"/>
    </Grid>
</Window>
